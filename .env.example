# ============================================
# PodChat Docker Compose Environment Variables
# ============================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env file to version control!

# PostgreSQL
# Generate a strong password: openssl rand -base64 32
POSTGRES_USER=podchat
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=podchat

# LiveKit
# Generate API key/secret: https://docs.livekit.io/home/self-hosting/keys/
LIVEKIT_API_KEY=CHANGE_THIS_API_KEY
LIVEKIT_API_SECRET=CHANGE_THIS_API_SECRET

# Cloudflare R2 / S3 Storage
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
