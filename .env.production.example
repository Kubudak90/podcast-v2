# ============================================
# PodChat Production Environment Variables
# ============================================
# IMPORTANT: Copy this file to .env and fill in your values
# Generate passwords with: openssl rand -base64 32

# ===================
# Domain Configuration
# ===================
DOMAIN=podchat.example.com
LIVEKIT_DOMAIN=livekit.podchat.example.com

# VPS public IP (for LiveKit)
VPS_IP=YOUR_VPS_IP_ADDRESS

# ===================
# PostgreSQL
# ===================
POSTGRES_USER=podchat
POSTGRES_PASSWORD=GENERATE_STRONG_PASSWORD_HERE
POSTGRES_DB=podchat

# ===================
# JWT
# ===================
# Generate: openssl rand -base64 64
JWT_SECRET=GENERATE_64_CHAR_SECRET_HERE

# ===================
# LiveKit
# ===================
# Generate: docker run --rm livekit/livekit-server generate-keys
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================
# Cloudflare R2 / S3 Storage
# ===================
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_BUCKET=podchat-recordings

# ===================
# Push Notifications (VAPID)
# ===================
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ===================
# Frontend Build Args
# ===================
VITE_API_URL=https://podchat.example.com
VITE_LIVEKIT_URL=wss://livekit.podchat.example.com

# ===================
# Backend URLs
# ===================
FRONTEND_URL=https://podchat.example.com
