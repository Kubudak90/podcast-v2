# ============================================
# PodChat Backend Environment Variables
# ============================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env file to version control!

# Database
# Generate a strong password: openssl rand -base64 32
POSTGRES_USER=podchat
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=podchat
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# JWT
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# LiveKit (Self-hosted)
# Generate API key/secret: https://docs.livekit.io/home/self-hosting/keys/
LIVEKIT_URL=ws://localhost:7880
# Production: LIVEKIT_URL=wss://livekit.yourdomain.com
LIVEKIT_API_KEY=CHANGE_THIS_API_KEY
LIVEKIT_API_SECRET=CHANGE_THIS_API_SECRET

# Cloudflare R2 / S3 Storage
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_BUCKET=podchat-recordings

# Push Notifications (VAPID)
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# App
PORT=3001
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://yourdomain.com
