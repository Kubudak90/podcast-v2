# ============================================
# PodChat Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Backend REST API base URL
VITE_API_URL=http://localhost:3001/api

# Backend Socket.IO base URL (usually same host as API, no /api suffix)
VITE_SOCKET_URL=http://localhost:3001

# LiveKit WebSocket URL (self-hosted or LiveKit Cloud)
# Production örneği: wss://livekit.yourdomain.com
VITE_LIVEKIT_URL=ws://localhost:7880

# Web Push (VAPID) — backend ile aynı public key olmalı
# Backend'de `npx web-push generate-vapid-keys` ile üretilir
VITE_VAPID_PUBLIC_KEY=

# Opsiyonel — Sentry/analytics
# VITE_SENTRY_DSN=
